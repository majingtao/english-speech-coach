# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic API Key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Moonshot (Kimi) API Key (get from https://platform.moonshot.cn/console/api-keys)
MOONSHOT_API_KEY=sk-...

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# HTTP Proxy for accessing OpenAI/Claude APIs (e.g. local Clash/V2Ray)
# Moonshot and OpenRouter usually no proxy needed
HTTP_PROXY=http://127.0.0.1:1080

# Optional: custom API base URLs
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com